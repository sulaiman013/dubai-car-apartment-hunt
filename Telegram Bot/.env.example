# Copy to .env and fill in:
TELEGRAM_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALLOWED_USER_ID=
OPENROUTER_API_KEY=sk-or-v1-...
MODEL=google/gemini-3.1-flash-lite-preview

# How to get TELEGRAM_TOKEN:
#   1. Open Telegram, search for "@BotFather", tap Start
#   2. Send /newbot, follow prompts (pick a name, pick a username ending in "bot")
#   3. BotFather replies with a token — paste it above
#
# How to get ALLOWED_USER_ID:
#   1. In Telegram, search for "@userinfobot", tap Start
#   2. It replies with "Id: 123456789" — that's your numeric user ID
#   3. Paste the number above (no quotes)
